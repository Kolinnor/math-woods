APP_DOMAIN=mathwoods.example
APP_URL=https://mathwoods.example
STATUS_DOMAIN=status.mathwoods.example
LETSENCRYPT_EMAIL=you@example.com

AUTH_SECRET=replace-with-at-least-32-random-characters
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace-with-base64-32-byte-random-key

POSTGRES_DB=math_woods
POSTGRES_USER=math_woods
POSTGRES_PASSWORD=replace-with-a-long-random-password

SMTP_HOST=mail.infomaniak.com
SMTP_PORT=465
SMTP_USER=contact@mathwoods.example
SMTP_PASSWORD=replace-with-mailbox-password
SMTP_FROM="Math Woods <contact@mathwoods.example>"
SMTP_SECURE=1
SMTP_STARTTLS=0
SMTP_AUTH_REQUIRED=1

# S3-compatible image storage, for example Infomaniak Object Storage.
IMAGE_STORAGE_ENDPOINT=https://replace-with-infomaniak-s3-endpoint
IMAGE_STORAGE_REGION=replace-with-infomaniak-region
IMAGE_STORAGE_BUCKET=mathwoods-images
IMAGE_STORAGE_ACCESS_KEY_ID=replace-with-object-storage-access-key
IMAGE_STORAGE_SECRET_ACCESS_KEY=replace-with-object-storage-secret-key
IMAGE_STORAGE_PUBLIC_BASE_URL=https://images.mathwoods.example
IMAGE_STORAGE_PATH_STYLE=1
IMAGE_UPLOAD_MAX_BYTES=5242880

# Optional offsite backup sync.
# Pick one destination and set SYNC_OFFSITE_BACKUPS=1 after testing it manually.
SYNC_OFFSITE_BACKUPS=0
OFFSITE_BACKUP_TARGET=
OFFSITE_BACKUP_RCLONE_REMOTE=

NEXT_TELEMETRY_DISABLED=1
