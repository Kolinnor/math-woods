# Production example. Copy to .env.production on the server and replace every value.
APP_DOMAIN=mathwoods.org
STATUS_DOMAIN=status.mathwoods.org
LETSENCRYPT_EMAIL=admin@mathwoods.org

# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-with-at-least-32-random-characters

POSTGRES_DB=math_woods
POSTGRES_USER=math_woods
# Use URL-safe characters. Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-long-random-password

NEXT_TELEMETRY_DISABLED=1
