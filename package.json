{
  "name": "math-woods",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "predev": "node scripts/clean-next-dev.mjs",
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/fix-next-server-chunks.mjs",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "achievements:backfill": "node scripts/backfill-achievements.mjs",
    "internal-links:reconcile": "node scripts/reconcile-internal-links.mjs",
    "db:seed": "node prisma/seed.mjs",
    "prod:build": "docker compose --env-file .env.production -f docker-compose.infomaniak.yml build",
    "prod:migrate": "docker compose --env-file .env.production -f docker-compose.infomaniak.yml run --rm migrate",
    "prod:up": "docker compose --env-file .env.production -f docker-compose.infomaniak.yml up -d app uptime-kuma caddy",
    "prod:logs": "docker compose --env-file .env.production -f docker-compose.infomaniak.yml logs -f app caddy",
    "test:core": "node --experimental-strip-types tests/core.test.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.11.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.0",
    "@prisma/client": "^6.8.0",
    "@xyflow/react": "^12.11.2",
    "jsxgraph": "^1.12.2",
    "katex": "^0.16.22",
    "lucide-react": "^0.511.0",
    "marked": "^15.0.12",
    "next": "^15.3.0",
    "prisma": "^6.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.13.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.0"
  }
}
